# 开发端口
PORT=
# 控制 p-limit 同时处理的 chunk 数，默认值 3
INGEST_CONCURRENCY=
# Tavily web_search 检索使用，免费 每月1000次/月
TAVILY_API_KEY=

## ========== 模型配置 ========== ##
# 阿里云百炼 API Key
OPENAI_API_KEY=
# API Base URL
OPENAI_BASE_URL=
# 对话模型名称（用于意图判断、tags 提取、回答生成）
CHAT_MODEL_NAME=
# Embedding 模型名称
EMBEDDINGS_MODEL_NAME=

## ========== Milvus 配置 ========== ##
# Milvus 服务地址（host:port）
MILVUS_ADDRESS=
# Milvus 用户名（可选）
MILVUS_USERNAME=
# Milvus 密码（可选）
MILVUS_PASSWORD=
# 知识库 Collection 名称
MILVUS_COLLECTION_NAME=
# 文档 Collection 名称，默认 documents
MILVUS_DOCUMENTS_COLLECTION_NAME=
# Embedding 向量维度，默认 1024，请注意，这个东西变更以后，数据必须要重新入库
EMBEDDING_DIMENSION= 

## ========== SQLite ========== ##
# SQLite 数据库文件路径，默认 data/rag.db
SQLITE_PATH=

## ========== MySQL ========== ##
# 数据库主机地址
DB_HOST=
# 数据库端口号
DB_PORT=
# 数据库用户名
DB_USER=
# 数据库密码
DB_PASSWORD=
# 数据库名称
DB_NAME=

## ========== 模型能力参数 ========== ##
# 模型上下文窗口总长度
MODEL_CONTEXT_WINDOW_TOKENS=
# 最大输入 token 数
MODEL_MAX_INPUT_TOKENS=
# 最大输出 token 数
MODEL_MAX_OUTPUT_TOKENS=
# 每分钟请求数限制
MODEL_RPM=
# 每分钟 token 数限制
MODEL_TPM=
# 思考模式最大输入
MODEL_MAX_INPUT_TOKENS_THINKING=
# 思考模式最大输出
MODEL_MAX_OUTPUT_TOKENS_THINKING=
# 最大思维链长度
MODEL_MAX_COT_TOKENS=
# Embedding 模型每分钟请求数限制，默认 1800
EMBEDDING_RPM=
# Embedding 模型每分钟 token 数限制，默认 1200000
EMBEDDING_TPM=

## ========== 回答与压缩 ========== ##
# 回答最大输出预算
ANSWER_MAX_OUTPUT_TOKENS=
# 强制压缩阈值百分比
TOKEN_HARD_THRESHOLD_PERCENT=

## ========== Agent ========== ##
# Agent 单轮最大循环次数
AGENT_RECURSION_LIMIT=

## ========== 记忆 ========== ##
# 记忆保留的最近对话轮数（1 轮 = user + assistant 各一条）
MEMORY_RECENT_ROUNDS=

## ========== Tool 检索 ========== ##
# 知识库检索返回条数
KNOWLEDGE_SEARCH_TOP_K=
# 文档检索返回条数
DOCUMENT_SEARCH_TOP_K=
# 联网搜索最大返回条数
WEB_SEARCH_MAX_RESULTS=
# 联网搜索单条结果最大字符数
WEB_SEARCH_MAX_CHARS=

## ========== 检索预算 ========== ##
# 最大保留片段数
RETRIEVAL_MAX_SNIPPETS=
# llmContext 最大字符数
RETRIEVAL_MAX_CHARS=
# 最低相似度分数阈值（0-1 之间的小数，低于此值直接丢弃）
RETRIEVAL_MIN_SCORE=
# 最大保留试题数
RETRIEVAL_MAX_EXERCISES=